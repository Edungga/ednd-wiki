views:
  - type: table
    name: All Spells
    filters:
      and:
        - file.tags.contains("Spell")
    order:
      - file.name
      - School
      - Spell Circle
      - Casting Time
      - Range
      - Components
      - Duration
      - Spell List
      - tags
    sort: []
    columnSize:
      note.Components: 151
      note.Duration: 208
      note.Spell List: 181
  - type: table
    name: Arcane Spells
    filters:
      and:
        - note["Spell List"].contains("Arcane")
